# --- Modo desenvolvimento (chave no front, NÃO subir para produção) ---
# VITE_RIOT_API_KEY=sua_chave_riot_aqui

# --- Modo produção (deploy no Vercel: chave fica só no painel do Vercel) ---
# No Vercel: Project → Settings → Environment Variables → RIOT_API_KEY
# Depois do deploy, use a URL do seu app + /api/riot:
# VITE_RIOT_API_PROXY=https://seu-app.vercel.app/api/riot
