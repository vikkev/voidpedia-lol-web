# --- Desenvolvimento local: apontar para o proxy (ex.: app já deployado no Vercel) ---
# Assim as requisições vão para o proxy e não para o localhost (evita 404).
# VITE_RIOT_API_PROXY=https://voidpedia-lol-web.vercel.app/api/riot

# --- Produção (deploy no Vercel) ---
# No Vercel: Project → Settings → Environment Variables:
#   RIOT_API_KEY=sua_chave_riot
#   VITE_RIOT_API_PROXY=https://seu-app.vercel.app/api/riot
